{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "strict": true,
    "isolatedModules": false
  },
  "exclude": ["node_modules"],
  "include": ["**/*.ts", "**/*.tsx", "jest.setup.ts", "next-env.d.ts"]
}
